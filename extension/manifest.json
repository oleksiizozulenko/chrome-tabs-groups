{
  "manifest_version": 3,
  "name": "Auto Tab Grouper - BETA",
  "version": "0.1.1",
  "description": "Automatically groups tabs by hostname per window with MRU and pin controls. THIS EXTENSION IS FOR BETA TESTING",
  "permissions": ["tabs", "tabGroups", "storage", "sidePanel"],
  "action": {
    "default_title": "Tab Groups Bar"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
